
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended information for a registered user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { 
          "type": "string", 
          "enum": ["buyer", "land_owner", "farmer", "staff"],
          "description": "User's primary role in the ecosystem."
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "LandLeaseRegistration": {
      "title": "Land Lease Registration",
      "description": "Details of farmers interested in leasing their land.",
      "type": "object",
      "properties": {
        "aadharName": {
          "type": "string",
          "description": "Full name as per Aadhar card."
        },
        "aadharNumber": {
          "type": "string",
          "description": "12-digit Aadhar number."
        },
        "village": {
          "type": "string",
          "description": "Village name."
        },
        "state": {
          "type": "string",
          "description": "State."
        },
        "district": {
          "type": "string",
          "description": "District."
        },
        "pincode": {
          "type": "string",
          "description": "6-digit postal code."
        },
        "mobile": {
          "type": "string",
          "description": "Mobile number for contact."
        },
        "fieldSize": {
          "type": "number",
          "description": "Numerical value of field size."
        },
        "fieldUnit": {
          "type": "string",
          "enum": ["Biswa", "Bigha"],
          "description": "Unit of measurement for the field."
        },
        "hasIrrigation": {
          "type": "boolean",
          "description": "Whether the land has irrigation facilities."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "contacted", "reviewed"],
          "description": "Status of the lead."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of registration."
        }
      },
      "required": ["aadharName", "aadharNumber", "village", "state", "district", "pincode", "mobile", "fieldSize", "fieldUnit"]
    },
    "Order": {
      "title": "Order",
      "description": "Details of a customer purchase.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["cod", "card"] },
        "status": { "type": "string", "enum": ["pending", "confirmed", "shipped", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/entities/UserProfile",
      "description": "User account and role data."
    },
    "/landLeaseRegistrations/{registrationId}": {
      "schema": "#/entities/LandLeaseRegistration",
      "description": "Collection of land lease registration applications."
    },
    "/orders/{orderId}": {
      "schema": "#/entities/Order",
      "description": "Collection of customer orders."
    }
  }
}
