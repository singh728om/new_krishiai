/**
 * KrishiAI Firestore Security Rules
 * 
 * Core Philosophy:
 * This ruleset implements a strict user-ownership model for personal agricultural data while 
 * maintaining public visibility for marketplace products and approved testimonials. Access 
 * control is primarily driven by path-based variables and denormalized ownership fields to 
 * ensure high performance and authorization independence.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function dataMatchesAuth(field) {
      return request.resource.data[field] == request.auth.uid;
    }

    function isImmutable(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && isImmutable('id');
      allow delete: if isExistingOwner(userId);

      match /farms/{farmId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && isImmutable('userId');
        allow delete: if isExistingOwner(userId);

        match /cropCycles/{cropCycleId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.farmId == farmId;
          allow update: if isExistingOwner(userId) && isImmutable('farmId');
          allow delete: if isExistingOwner(userId);
        }
      }

      match /diagnosticReports/{reportId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && isImmutable('userId');
        allow delete: if isExistingOwner(userId);
      }
    }

    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn() && dataMatchesAuth('ownerId'); 
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid && isImmutable('ownerId');
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /testimonials/{testimonialId} {
      allow get: if resource.data.isApproved == true;
      allow list: if resource.data.isApproved == true;
      allow create, update, delete: if false; 
    }

    // Role-based collections
    match /user_roles_buyer/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId);
    }
    match /user_roles_landowner/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId);
    }
    match /user_roles_staff/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId);
    }

    // Land Lease Registrations
    match /landLeaseRegistrations/{regId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || exists(/databases/$(database)/documents/user_roles_staff/$(request.auth.uid)));
      allow create: if isSignedIn();
      allow update, delete: if exists(/databases/$(database)/documents/user_roles_staff/$(request.auth.uid));
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }
  }
}
